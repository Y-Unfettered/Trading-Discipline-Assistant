{
  "name": "trade-discipline-journal",
  "version": "0.3.3",
  "private": true,
  "description": "本地部署的个人交易计划、证据、执行与纪律复盘助手",
  "scripts": {
    "start": "node scripts/start-local-stack.mjs",
    "dev": "concurrently -k \"node scripts/start-local-stack.mjs\" \"vite\"",
    "app:start": "node server.js",
    "newsnow:install": "cross-env SKIP_INSTALL_SIMPLE_GIT_HOOKS=1 pnpm --dir vendor/newsnow install --frozen-lockfile",
    "newsnow:build": "pnpm --dir vendor/newsnow run build",
    "stocks:update": "python scripts/update-stock-db.py",
    "research:cli": "node scripts/research-import-cli.mjs",
    "check:ui": "node scripts/check-ui-baseline.mjs",
    "typecheck": "vue-tsc --noEmit -p tsconfig.app.json",
    "build": "npm run check:ui && npm run typecheck && vite build",
    "test": "npm run check:ui && node --test \"test/*.test.js\""
  },
  "engines": {
    "node": ">=22.5"
  },
  "dependencies": {
    "@tanstack/vue-table": "^8.21.3",
    "@vee-validate/zod": "^4.15.1",
    "@vueuse/core": "^14.3.0",
    "cheerio": "^1.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.4.12",
    "lucide-vue-next": "^0.468.0",
    "marked": "^18.0.2",
    "reka-ui": "^2.10.1",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.4.0",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.17",
    "vue-sonner": "^2.0.9",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.11",
    "@types/node": "^24.0.15",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vue/tsconfig": "^0.7.0",
    "concurrently": "^9.2.0",
    "shadcn-vue": "2.7.4",
    "tailwindcss": "^4.1.11",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vue-tsc": "^2.2.12"
  }
}
